# =========================
# Dependencies (all levels)
# =========================
**/node_modules
.pnp
.pnp.js

# =========================
# Next.js build output (all levels)
# =========================
**/.next
**/out

# =========================
# Build artifacts (all levels)
# =========================
**/dist
**/build
**/.turbo

# =========================
# Environment variables
# =========================
**/.env
**/.env.*

# =========================
# Test & coverage
# =========================
**/coverage

# =========================
# Vercel
# =========================
.vercel

# =========================
# Logs
# =========================
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# OS files
# =========================
**/.DS_Store
Thumbs.db

# =========================
