{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "apps/**/eslint.config.js",
        "apps/**/.prettierrc.js",
        "commitlint.config.js",
        "**/*.ts",
        "*.tsx",
        "**/*.js",
        "**/*.jsx"
      ]
    },
    "commitlint": {
      "inputs": ["commitlint.config.js"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
